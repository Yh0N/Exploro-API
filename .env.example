# ============================================================
# EXPLORO API — Archivo de configuración de ejemplo
# Copia este archivo a .env y ajusta los valores.
# ============================================================
#
# Con Docker Compose (recomendado):
#   Deja POSTGRES_HOST=db y @db en DATABASE_URL.
#   El nombre "db" es el servicio en docker-compose.yml.
#
# Sin Docker Compose (desarrollo local directo):
#   POSTGRES_HOST=localhost
#   DATABASE_URL=postgresql://exploro_user:exploro_password@localhost:5432/exploro_db
#

# ── Base de datos PostgreSQL ─────────────────────────────────────
POSTGRES_USER=exploro_user
POSTGRES_PASSWORD=exploro_password
POSTGRES_DB=exploro_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://exploro_user:exploro_password@db:5432/exploro_db

# ── Autenticación JWT ────────────────────────────────────────────
# Generá una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TU_CLAVE_SECRETA_AQUI_MINIMO_32_CARACTERES
ALGORITHM=HS256
# Expiración del access token en minutos (corta vida por seguridad)
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Expiración del refresh token en días
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── OAuth2 Google ────────────────────────────────────────────────
# Obtené estas credenciales en: https://console.cloud.google.com/
# 1. Crear proyecto → APIs & Services → Credentials → OAuth 2.0 Client IDs
# 2. Tipo: Web application
# 3. Authorized redirect URIs: http://localhost:8000/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=TU_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback


# ── Frontend ─────────────────────────────────────────────────────
# URL base del frontend (Next.js/React) para redireccionamientos post-OAuth
FRONTEND_URL=http://localhost:3000
