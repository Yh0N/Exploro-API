# Copia este archivo a .env y ajusta valores.
#
# Con Docker Compose (recomendado): deja POSTGRES_HOST=db y @db en DATABASE_URL.
# El nombre "db" es el servicio en docker-compose.yml; solo resuelve dentro de esa red.
#
# Si corres SOLO el contenedor de la API sin compose: Postgres debe ser accesible desde el host
# (p. ej. contenedor db con -p 5432:5432) y usa:
#   POSTGRES_HOST=host.docker.internal
#   DATABASE_URL=postgresql://exploro_user:exploro_password@host.docker.internal:5432/exploro_db

POSTGRES_USER=exploro_user
POSTGRES_PASSWORD=exploro_password
POSTGRES_DB=exploro_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql://exploro_user:exploro_password@db:5432/exploro_db

SECRET_KEY=TU_CLAVE_SECRETA_AQUI
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
